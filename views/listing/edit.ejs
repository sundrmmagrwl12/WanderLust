<% layout('/layouts/boilerplate.ejs') %>

<div class="bg-slate-50/50 min-h-screen py-12 flex justify-center px-4 sm:px-6">
  <div class="w-full max-w-2xl bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-premium h-fit">
    
    <!-- Title Area -->
    <div class="mb-8 border-b border-gray-100 pb-5">
      <h2 class="font-serif text-3xl font-bold text-gray-900">Edit Your Listing</h2>
      <p class="text-sm font-medium text-gray-500 mt-1.5">Update the details and photos for your stay.</p>
    </div>

    <form
      action="/wanderlust/listings/<%= listing._id %>?_method=PATCH"
      method="POST"
      class="space-y-6"
      enctype="multipart/form-data"
    >
      
      <!-- Title -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Title</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
            <i class="fa-solid fa-hotel text-xs"></i>
          </span>
          <input
            type="text"
            name="listing[title]"
            required
            minlength="3"
            placeholder="Add a catchy title"
            value="<%= listing.title %>"
            class="peer w-full pl-11 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
          />
          <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
            Title is required (minimum 3 characters).
          </p>
        </div>
      </div>

      <!-- Description -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Description</label>
        <textarea
          name="listing[description]"
          rows="4"
          required
          minlength="10"
          placeholder="Describe your listing"
          class="peer w-full px-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
        ><%= listing.description %></textarea>
        <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
          Description must be at least 10 characters.
        </p>
      </div>

      <!-- Image Preview and Upload -->
      <div class="space-y-4">
        <!-- Current Image Preview -->
        <div class="space-y-2">
          <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider">Current Cover Photo</label>
          <div class="w-40 aspect-[4/3] rounded-xl overflow-hidden border border-gray-200 shadow-sm bg-zinc-150">
            <img src="<%= originalUrl %>" alt="Current Cover" class="w-full h-full object-cover">
          </div>
        </div>

        <!-- Upload New Image -->
        <div class="space-y-1">
          <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Upload New Photo (Optional)</label>
          <div class="flex items-center justify-center w-full">
            <label class="flex flex-col items-center justify-center w-full h-28 border-2 border-gray-200 border-dashed rounded-2xl cursor-pointer bg-zinc-50 hover:bg-zinc-100/50 transition">
              <div class="flex flex-col items-center justify-center pt-4 pb-4">
                <i class="fa-solid fa-cloud-arrow-up text-gray-400 text-xl mb-1.5"></i>
                <p class="mb-0.5 text-xs font-bold text-gray-600">Select a new image file</p>
                <p class="text-xxs text-gray-400">PNG, JPG, JPEG, or WEBP (Max width 1000px)</p>
              </div>
              <input
                type="file"
                name="listing[image]"
                class="hidden"
                onchange="document.getElementById('file-chosen-edit').textContent = this.files[0].name"
              />
            </label>
          </div>
          <span id="file-chosen-edit" class="text-xs font-semibold text-brand-500 block pt-1.5">No new file chosen</span>
        </div>
      </div>

      <!-- Price & Country -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Price -->
        <div class="space-y-1">
          <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Price (₹ / Night)</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-450 font-bold text-xs">
              ₹
            </span>
            <input
              type="number"
              name="listing[price]"
              required
              min="1"
              placeholder="e.g. 1200"
              value="<%= listing.price %>"
              class="peer w-full pl-9 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
            />
            <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
              Price must be greater than 0.
            </p>
          </div>
        </div>

        <!-- Country -->
        <div class="space-y-1">
          <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Country</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
              <i class="fa-solid fa-globe text-xs"></i>
            </span>
            <input
              type="text"
              name="listing[country]"
              required
              placeholder="India"
              value="<%= listing.country %>"
              class="peer w-full pl-11 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
            />
            <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
              Country is required.
            </p>
          </div>
        </div>
      </div>

      <!-- Location -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Location</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
            <i class="fa-solid fa-location-dot text-xs"></i>
          </span>
          <input
            type="text"
            name="listing[location]"
            required
            placeholder="Noida, Uttar Pradesh"
            value="<%= listing.location %>"
            class="peer w-full pl-11 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
          />
          <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
            Location is required.
          </p>
        </div>
      </div>

      <!-- Buttons -->
      <div class="pt-4 border-t border-gray-100 flex items-center justify-end gap-3">
        <a href="/wanderlust/listings/<%= listing._id %>" class="px-6 py-3 rounded-full text-xs font-bold text-gray-500 hover:bg-gray-50 transition">
          Cancel
        </a>
        <button
          type="submit"
          class="bg-brand-500 hover:bg-brand-600 active:scale-95 text-white font-bold text-xs px-8 py-3 rounded-full transition shadow-button"
        >
          Save Changes
        </button>
      </div>

    </form>
  </div>
</div>
