<% layout('/layouts/boilerplate.ejs') %>

<div class="bg-slate-50/50 min-h-screen py-12 flex justify-center px-4 sm:px-6">
  <div class="w-full max-w-2xl bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-premium h-fit">
    
    <!-- Title Area -->
    <div class="mb-8 border-b border-gray-100 pb-5">
      <h2 class="font-serif text-3xl font-bold text-gray-900">Host a New Stay</h2>
      <p class="text-sm font-medium text-gray-500 mt-1.5">Share your amazing home with travelers from around the world.</p>
    </div>

    <form action="/wanderlust/listings" method="POST" class="space-y-6" enctype="multipart/form-data">
      
      <!-- Title -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Title</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
            <i class="fa-solid fa-hotel text-xs"></i>
          </span>
          <input
            type="text"
            name="listing[title]"
            required
            minlength="3"
            placeholder="e.g. Charming Beachfront Cottage"
            class="peer w-full pl-11 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
          />
          <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
            Title is required (minimum 3 characters).
          </p>
        </div>
      </div>

      <!-- Description -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Description</label>
        <textarea
          name="listing[description]"
          rows="4"
          required
          minlength="10"
          placeholder="What makes your place special? List amenities, view, and nearby spots..."
          class="peer w-full px-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
        ></textarea>
        <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
          Description must be at least 10 characters.
        </p>
      </div>

      <!-- Image File Upload -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Listing Cover Photo</label>
        <div class="flex items-center justify-center w-full">
          <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-200 border-dashed rounded-2xl cursor-pointer bg-zinc-50 hover:bg-zinc-100/50 transition">
            <div class="flex flex-col items-center justify-center pt-5 pb-6">
              <i class="fa-solid fa-cloud-arrow-up text-gray-400 text-2xl mb-2"></i>
              <p class="mb-1 text-xs font-bold text-gray-600">Click to upload image</p>
              <p class="text-xxs text-gray-400">PNG, JPG, JPEG, or WEBP (Max width 1000px)</p>
            </div>
            <input
              type="file"
              name="listing[image]"
              required
              class="hidden"
              onchange="document.getElementById('file-chosen').textContent = this.files[0].name"
            />
          </label>
        </div>
        <span id="file-chosen" class="text-xs font-semibold text-brand-500 block pt-1.5">No file chosen</span>
      </div>

      <!-- Dual Column: Price & Country -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Price -->
        <div class="space-y-1">
          <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Price (₹ / Night)</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400 font-bold text-xs">
              ₹
            </span>
            <input
              type="number"
              name="listing[price]"
              required
              min="1"
              placeholder="e.g. 1500"
              class="peer w-full pl-9 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
            />
            <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
              Price must be greater than 0.
            </p>
          </div>
        </div>

        <!-- Country -->
        <div class="space-y-1">
          <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Country</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
              <i class="fa-solid fa-globe text-xs"></i>
            </span>
            <input
              type="text"
              name="listing[country]"
              required
              placeholder="e.g. United States"
              class="peer w-full pl-11 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
            />
            <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
              Country is required.
            </p>
          </div>
        </div>
      </div>

      <!-- Location -->
      <div class="space-y-1">
        <label class="block text-xs font-bold text-gray-550 uppercase tracking-wider mb-2">Location / City</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
            <i class="fa-solid fa-location-dot text-xs"></i>
          </span>
          <input
            type="text"
            name="listing[location]"
            required
            placeholder="e.g. Malibu, California"
            class="peer w-full pl-11 pr-4 py-3 border border-gray-200 rounded-2xl bg-zinc-50 text-sm focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none transition invalid:border-red-200"
          />
          <p class="mt-1.5 text-xs text-red-500 hidden peer-invalid:block peer-placeholder-shown:hidden">
            Location/City is required.
          </p>
        </div>
      </div>

      <!-- Buttons -->
      <div class="pt-4 border-t border-gray-100 flex items-center justify-end gap-3">
        <a href="/wanderlust/listings" class="px-6 py-3 rounded-full text-xs font-bold text-gray-500 hover:bg-gray-50 transition">
          Cancel
        </a>
        <button
          type="submit"
          class="bg-brand-500 hover:bg-brand-600 active:scale-95 text-white font-bold text-xs px-8 py-3 rounded-full transition shadow-button"
        >
          Create Listing
        </button>
      </div>

    </form>
  </div>
</div>
