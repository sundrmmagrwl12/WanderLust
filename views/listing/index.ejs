<%- layout('/layouts/boilerplate.ejs') %>

<div class="bg-slate-50/50 min-h-screen py-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Mobile Search Form -->
    <form
      action="/wanderlust/search"
      method="get"
      class="md:hidden flex items-center gap-3 mb-6"
    >
      <div class="relative w-full">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-gray-400">
          <i class="fa-solid fa-magnifying-glass text-xs"></i>
        </span>
        <input
          type="text"
          name="q"
          placeholder="Search your destination..."
          required
          class="w-full pl-10 pr-4 py-2 border border-gray-250 rounded-full bg-white text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="bg-brand-500 hover:bg-brand-600 active:scale-95 text-white text-xs font-bold px-4 py-2.5 rounded-full transition shadow-button"
      >
        Search
      </button>
    </form>

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-gray-100 pb-5 mb-8">
      <div>
        <h2 class="font-serif text-3xl md:text-4xl font-bold tracking-tight text-gray-900">
          Featured Stays
        </h2>
        <p class="text-gray-500 text-sm mt-1.5 font-medium">
          Handpicked premium destinations loved by travelers
        </p>
      </div>
    
      <!-- Sorting Dropdown -->
      <form action="/wanderlust/listings" method="GET" class="mt-4 md:mt-0">
        <div class="relative flex items-center">
          <span class="absolute left-3 text-gray-400 pointer-events-none">
            <i class="fa-solid fa-arrow-down-wide-narrow text-xs"></i>
          </span>
          <select
            name="sort"
            onchange="this.form.submit()"
            class="pl-9 pr-8 py-2 border border-gray-200 rounded-xl text-sm font-semibold bg-white text-gray-700 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-100 focus:outline-none appearance-none cursor-pointer"
          >
            <option value="">Sort By</option>
            <option value="low" <%= typeof sort !== 'undefined' && sort === 'low' ? 'selected' : '' %>>
              Price: Low to High
            </option>
            <option value="high" <%= typeof sort !== 'undefined' && sort === 'high' ? 'selected' : '' %>>
              Price: High to Low
            </option>
          </select>
          <span class="absolute right-3 text-gray-450 pointer-events-none">
            <i class="fa-solid fa-chevron-down text-xxs"></i>
          </span>
        </div>
      </form>
    </div>

    <!-- Listings Grid -->
    <% if (allListings.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
        <% for (let listing of allListings) { %>
          <div class="group relative flex flex-col w-full bg-white rounded-3xl p-3 border border-gray-100 shadow-premium transition-all duration-300 hover:shadow-premium-hover">
            <a href="/wanderlust/listings/<%= listing._id %>" class="flex flex-col h-full">
              <!-- Image Wrap -->
              <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden bg-gray-100 relative">
                <img
                  src="<%= listing.image.path %>"
                  alt="listing image"
                  loading="lazy"
                  class="w-full h-full object-cover transform duration-500 ease-out group-hover:scale-105"
                />
                
                <!-- Like Button Badge -->
                <button type="button" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white/95 hover:bg-white flex items-center justify-center shadow-sm border border-gray-100 transition duration-200 text-gray-450 hover:text-rose-500">
                  <i class="fa-regular fa-heart text-xs"></i>
                </button>
              </div>

              <!-- Content details -->
              <div class="pt-4 pb-2 flex-grow flex flex-col justify-between">
                <div class="space-y-1">
                  <!-- Location / Country Badge -->
                  <p class="text-xxs font-bold uppercase tracking-wider text-brand-500">
                    <%= listing.location %>, <%= listing.country %>
                  </p>
                  
                  <!-- Title -->
                  <h3 class="text-sm font-bold text-gray-900 group-hover:text-brand-500 transition-colors line-clamp-1">
                    <%= listing.title %>
                  </h3>
                </div>

                <!-- Pricing -->
                <div class="mt-3 flex items-baseline justify-between pt-2 border-t border-gray-50">
                  <p class="text-xs text-gray-550">Price</p>
                  <p class="text-sm font-bold text-gray-900">
                    ₹<%= listing.price != null ? listing.price.toLocaleString('en-IN') : "N/A" %> <span class="text-xs font-semibold text-gray-500">/ 2 Day</span>
                  </p>
                </div>
              </div>
            </a>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- Empty State -->
    <% if (allListings.length == 0) { %>
      <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-3xl border border-gray-100 p-8 shadow-sm">
        <div class="w-16 h-16 rounded-full bg-rose-50 flex items-center justify-center text-brand-500 mb-5">
          <i class="fa-solid fa-hotel text-2xl"></i>
        </div>

        <h2 class="text-xl font-bold text-gray-900 mb-2">
          No Results Found
        </h2>

        <p class="text-gray-500 max-w-sm text-sm">
          We couldn't find any stays matching your criteria. Try adjusting your search query or view all listings.
        </p>

        <a
          href="/wanderlust/listings"
          class="mt-6 inline-block rounded-full bg-brand-500 hover:bg-brand-600 active:scale-95 text-white font-bold text-xs px-6 py-3 transition shadow-button"
        >
          View All Listings
        </a>
      </div>
    <% } %>

  </div>
</div>
