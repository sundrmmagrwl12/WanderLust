<% layout('/layouts/boilerplate.ejs') %>

<main class="flex min-h-[85vh] items-center justify-center bg-slate-50/50 px-4 py-12">
  <div class="w-full max-w-md bg-white rounded-3xl border border-gray-100 p-8 text-center shadow-premium">
    <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-rose-50 text-brand-500 mb-6">
      <i class="fa-solid fa-triangle-exclamation text-2xl"></i>
    </div>
    
    <h1 class="font-serif text-2xl font-bold text-gray-900 mb-2">
      Something Went Wrong
    </h1>
    
    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">
      Error Details
    </p>
    
    <div class="bg-rose-50/50 border border-rose-100 rounded-2xl p-4 text-left text-sm text-brand-700 font-medium break-words mb-8">
      <%= err.message %>
    </div>
    
    <a
      href="/wanderlust/listings"
      class="inline-flex items-center gap-2 bg-gray-900 hover:bg-brand-500 text-white font-bold text-xs px-6 py-3 rounded-full transition shadow-sm hover:shadow-button"
    >
      <i class="fa-solid fa-arrow-left-long"></i>
      Return to Explorer
    </a>
  </div>
</main>
