  <!-- Footer Bottom -->
  <div class="border-t border-zinc-900 py-6 text-center text-xs text-zinc-650">
    &copy; <%= new Date().getFullYear() %> Wanderlust Pvt Ltd. All rights reserved.
  </div>
</footer>
