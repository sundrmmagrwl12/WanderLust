<div class="fixed top-[4.5rem] lg:top-[5.5rem] inset-x-0 z-[9999] pointer-events-none flex flex-col gap-3">
  <% if (error && error.length > 0) { %>
    <div
      class="flex items-center justify-between pointer-events-auto mx-auto w-11/12 max-w-md rounded-2xl border border-rose-100 bg-white/90 backdrop-blur-md px-4 py-3.5 text-rose-800 shadow-premium animate-fade-in"
      role="alert"
    >
      <div class="flex items-center gap-3">
        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-rose-50 text-brand-500">
          <i class="fa-solid fa-circle-exclamation text-sm"></i>
        </span>
        <span class="text-xs font-bold text-gray-800">
          <%= error[0] %>
        </span>
      </div>

      <button type="button" class="text-gray-400 hover:text-gray-600 transition p-1 text-xs"
        onclick="this.parentElement.remove()">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
  <% } %>

  <% if (success && success.length > 0) { %>
    <div
      class="flex items-center justify-between pointer-events-auto mx-auto w-11/12 max-w-md rounded-2xl border border-emerald-100 bg-white/90 backdrop-blur-md px-4 py-3.5 text-emerald-800 shadow-premium animate-fade-in"
      role="alert"
    >
      <div class="flex items-center gap-3">
        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-emerald-50 text-emerald-500">
          <i class="fa-solid fa-circle-check text-sm"></i>
        </span>
        <span class="text-xs font-bold text-gray-800">
          <%= success[0] %>
        </span>
      </div>

      <button type="button" class="text-gray-400 hover:text-gray-600 transition p-1 text-xs"
        onclick="this.parentElement.remove()">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
  <% } %>
</div>